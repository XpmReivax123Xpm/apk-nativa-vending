<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E1117"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvCatalogTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="MQ-2103"
            android:textColor="#F4F8FF"
            android:textSize="38sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCatalogSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Madrejon"
            android:textColor="#AFC8E9"
            android:textSize="20sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/vfPromoCarousel"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_catalog_promo_1"
        android:gravity="bottom|start"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/tvPromoTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Promociones"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPromoSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Espacio para ofertas y anuncios"
            android:textColor="#E9F4FF"
            android:textSize="18sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvCatalogStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_catalog_status"
        android:padding="10dp"
        android:text="Cargando catalogo..."
        android:textColor="#DCE8F6"
        android:textSize="16sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/llCatalogContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>
</LinearLayout>
