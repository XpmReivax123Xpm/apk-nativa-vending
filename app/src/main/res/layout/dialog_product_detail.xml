<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_modal_surface"
    android:orientation="vertical"
    android:padding="16dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:background="@drawable/bg_catalog_image_placeholder">

        <ImageView
            android:id="@+id/ivProductPreview"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:contentDescription="preview"
            android:src="@android:drawable/ic_menu_gallery" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvDialogProductCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="A1"
        android:textColor="#0965AF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDialogProductName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Producto"
        android:textColor="#0965AF"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvDialogProductStock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Stock disponible: 0"
        android:textColor="#F28E1B"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnQtyMinus"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:backgroundTint="#0965AF"
            android:textColor="#FFFFFF"
            android:text="-" />

        <TextView
            android:id="@+id/tvDialogQty"
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="1"
            android:textColor="#0965AF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnQtyPlus"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:backgroundTint="#0965AF"
            android:textColor="#FFFFFF"
            android:text="+" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnAddCart"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginRight="6dp"
            android:layout_weight="1"
            android:backgroundTint="#0965AF"
            android:textColor="#FFFFFF"
            android:text="Agregar carrito" />

        <Button
            android:id="@+id/btnBuyNow"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginLeft="6dp"
            android:layout_weight="1"
            android:backgroundTint="#F28E1B"
            android:textColor="#FFFFFF"
            android:text="Comprar ahora" />
    </LinearLayout>

</LinearLayout>
