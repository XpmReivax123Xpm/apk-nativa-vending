<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="315"
                android:startColor="#596A88"
                android:endColor="#3E4E6C"
                android:type="linear" />
