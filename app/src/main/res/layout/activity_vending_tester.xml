<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tester_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="14dp"
        android:background="@drawable/bg_mode_frame"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tester_header"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <ImageView
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/bg_icon_badge"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_manage"
                android:tint="#1F73C9" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:fontFamily="sans-serif-black"
                android:text="Vending Tester"
                android:textColor="#68DBF8"
                android:textSize="22sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_tester_panel"
            android:orientation="vertical"
            android:padding="14dp">

            <EditText
                android:id="@+id/etPort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:clickable="false"
                android:cursorVisible="false"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:hint="/dev/ttyS1"
                android:longClickable="false"
                android:paddingBottom="8dp"
                android:text="/dev/ttyS1"
                android:textIsSelectable="false"
                android:textColor="#E5EDF8"
                android:textColorHint="#A3B8CD"
                android:textSize="18sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#385271" />

            <EditText
                android:id="@+id/etBaud"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:clickable="false"
                android:cursorVisible="false"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:hint="9600"
                android:inputType="number"
                android:longClickable="false"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="9600"
                android:textIsSelectable="false"
                android:textColor="#E5EDF8"
                android:textColorHint="#A3B8CD"
                android:textSize="18sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#385271" />

            <EditText
                android:id="@+id/etCell"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:hint="Pedido (ej: 38,40,22)"
                android:inputType="text"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:textColor="#E5EDF8"
                android:textColorHint="#A3B8CD"
                android:textSize="18sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#385271" />

            <TextView
                android:id="@+id/tvPrompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=""
                android:textColor="#AFC2D6"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_connect"
                android:backgroundTint="@null"
                android:text="Conectar"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:backgroundTint="@null" />

            <Space
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnVendTest"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_start"
                android:backgroundTint="@null"
                android:text="Iniciar Pedido"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:backgroundTint="@null" />
        </LinearLayout>

        <Button
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_btn_toggle_action"
            android:backgroundTint="@null"
            android:enabled="false"
            android:text="Continuar con el siguiente pedido"
            android:textAllCaps="false"
            android:textColor="@color/text_btn_toggle_action"
            android:textSize="16sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnResetLift"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_btn_toggle_action"
            android:backgroundTint="@null"
            android:enabled="false"
            android:text="RESET LIFT (volver a base)"
            android:textAllCaps="false"
            android:textColor="@color/text_btn_toggle_action"
            android:textSize="16sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_btn_stop"
            android:backgroundTint="@null"
            android:text="Stop"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:backgroundTint="@null" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Log:"
            android:textColor="#BFD3E9"
            android:textSize="14sp" />

        <ScrollView
            android:id="@+id/svLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tester_log"
            android:fillViewport="true">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="LOG:\n"
                android:textColor="#53E67C"
                android:textSize="14sp" />
        </ScrollView>
    </LinearLayout>
</FrameLayout>
