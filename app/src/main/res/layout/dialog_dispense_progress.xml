<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_modal_surface"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="20dp"
    android:paddingEnd="24dp"
    android:paddingBottom="18dp">

    <ImageView
        android:id="@+id/ivDispenseHourglass"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_marginBottom="6dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/reloj_de_arena" />

    <TextView
        android:id="@+id/tvDispenseTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Dispensando productos..."
        android:textColor="#0965AF"
        android:textSize="34sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDispenseProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:text="1 de 1"
        android:textColor="#0E2B4A"
        android:textSize="48sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDispenseProductName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Producto"
        android:textColor="#0E2B4A"
        android:textSize="26sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/ivDispenseProduct"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_catalog_image_placeholder"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@android:drawable/ic_menu_gallery" />

    <TextView
        android:id="@+id/tvDispenseStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:text="Espera un momento, por favor..."
        android:textColor="#F28E1B"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDispenseTimer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="#7B8A9A"
        android:textSize="13sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnDispenseClose"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#0965AF"
        android:textColor="#FFFFFF"
        android:text="Cerrar"
        android:visibility="gone" />

</LinearLayout>
