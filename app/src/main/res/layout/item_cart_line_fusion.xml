<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="92dp"
            android:layout_height="66dp"
            android:background="@drawable/bg_catalog_image_placeholder">

            <ImageView
                android:id="@+id/ivFusionCartItemPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="preview"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvFusionCartItemName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="Producto"
                android:textColor="#20344D"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFusionCartItemPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Unitario: Bs 0.00"
                android:textColor="#5C7997"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvFusionCartItemSubtotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:text="0.00 Bs"
            android:textColor="#20344D"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:layout_width="100dp"
            android:layout_height="1dp" />

        <ImageButton
            android:id="@+id/btnFusionCartQtyMinus"
            android:layout_width="34dp"
            android:layout_height="32dp"
            android:backgroundTint="#F28E1B"
            android:contentDescription="restar"
            android:padding="7dp"
            android:src="@drawable/ic_minus_white" />

        <TextView
            android:id="@+id/tvFusionCartQty"
            android:layout_width="34dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="1"
            android:textColor="#0965AF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnFusionCartQtyPlus"
            android:layout_width="34dp"
            android:layout_height="32dp"
            android:backgroundTint="#0965AF"
            android:contentDescription="sumar"
            android:padding="7dp"
            android:src="@drawable/ic_plus_white" />

        <ImageButton
            android:id="@+id/btnFusionCartRemove"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="8dp"
            android:background="@android:color/transparent"
            android:contentDescription="quitar item"
            android:padding="5dp"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="#D94A3A" />
    </LinearLayout>

    <View
        android:id="@+id/vFusionCartItemDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:background="#D6E0EA" />

</LinearLayout>
