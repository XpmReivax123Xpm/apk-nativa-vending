<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_modal_surface"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvCartDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Carrito"
        android:textColor="#0965AF"
        android:textSize="22sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_marginTop="10dp"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:id="@+id/llCartItemsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <TextView
        android:id="@+id/tvCartDialogTotal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Total: Bs 0.00"
        android:textColor="#F28E1B"
        android:textSize="20sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCartClear"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:backgroundTint="#0965AF"
            android:text="Vaciar"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnCartClose"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:backgroundTint="#7A8A99"
            android:text="Cerrar"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnCartBuy"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:backgroundTint="#F28E1B"
            android:text="Comprar"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
