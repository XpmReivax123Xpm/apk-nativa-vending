<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_modal_surface"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="14dp"
    android:paddingEnd="20dp"
    android:paddingBottom="14dp">

    <ImageView
        android:id="@+id/ivDispenseHourglass"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="4dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/reloj_de_arena" />

    <TextView
        android:id="@+id/tvDispenseTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="DISPENSANDO..."
        android:textColor="#0965AF"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDispenseProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="1 de 1"
        android:textColor="#0E2B4A"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDispenseProductName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center"
        android:text="Producto"
        android:textColor="#0E2B4A"
        android:textSize="28sp" />

    <ImageView
        android:id="@+id/ivDispenseProduct"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginTop="6dp"
        android:scaleType="fitCenter"
        android:src="@android:drawable/ic_menu_gallery" />

    <TextView
        android:id="@+id/tvDispenseStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Espere un momento, por favor..."
        android:textColor="#000000"
        android:textStyle="bold"
        android:textSize="28sp" />

    <TextView
        android:id="@+id/tvDispenseTimer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="#7B8A9A"
        android:textSize="13sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnDispenseClose"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#0965AF"
        android:textColor="#FFFFFF"
        android:text="Cerrar"
        android:visibility="gone" />

</LinearLayout>
