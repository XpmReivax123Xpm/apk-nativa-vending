<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="315"
                android:startColor="#5C4D99"
                android:endColor="#4D3F85"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#8B7ACD" />
        </shape>
    </item>
</selector>
