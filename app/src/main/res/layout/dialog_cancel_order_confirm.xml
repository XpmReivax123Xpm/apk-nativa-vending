<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_modal_surface"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvCancelOrderTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CANCELAR PEDIDO"
        android:textColor="#000000"
        android:textSize="21sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvCancelOrderMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="¿Estas seguro de cancelar el pedido?"
        android:textColor="#0965AF"
        android:textStyle="bold"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancelOrderNo"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:backgroundTint="#0965AF"
            android:text="NO"
            android:textSize="22sp"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnCancelOrderYes"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:backgroundTint="#F28E1B"
            android:text="SI"
            android:textSize="22sp"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
