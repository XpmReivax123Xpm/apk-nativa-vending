<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/tvCheckoutDialogTimer"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="top|end"
        android:layout_marginEnd="16dp"
        android:background="@android:color/transparent"
        android:gravity="center"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:shadowColor="#80000000"
        android:shadowDx="0"
        android:shadowDy="1"
        android:shadowRadius="2"
        android:text="60s"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:translationY="-10dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="54dp"
        android:background="@drawable/bg_modal_surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

        <TextView
            android:id="@+id/tvCheckoutSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Resumen"
            android:textColor="#0965AF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCheckoutMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Metodo de pago: QR"
            android:textColor="#F28E1B"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etCheckoutName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="#0965AF"
            android:hint="Nombre completo"
            android:textColor="#1D2B36"
            android:textColorHint="#6E7E8B"
            android:inputType="textPersonName" />

        <EditText
            android:id="@+id/etCheckoutPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="#0965AF"
            android:hint="Telefono"
            android:textColor="#1D2B36"
            android:textColorHint="#6E7E8B"
            android:inputType="phone" />

        <EditText
            android:id="@+id/etCheckoutCi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="#0965AF"
            android:hint="CI / NIT"
            android:textColor="#1D2B36"
            android:textColorHint="#6E7E8B"
            android:inputType="text" />

        <TextView
            android:id="@+id/tvCheckoutError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#B3261E"
            android:textSize="13sp"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/progressCheckout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:indeterminateTint="#F28E1B"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCheckoutCancel"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginRight="6dp"
                android:layout_weight="1"
                android:backgroundTint="#0965AF"
                android:textColor="#FFFFFF"
                android:text="Cancelar" />

            <Button
                android:id="@+id/btnCheckoutGenerate"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginLeft="6dp"
                android:layout_weight="1"
                android:backgroundTint="#F28E1B"
                android:textColor="#FFFFFF"
                android:text="Generar QR" />
        </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
