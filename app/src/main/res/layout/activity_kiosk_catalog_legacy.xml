<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_kiosk_catalog_screen_hot">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="12dp"
            android:paddingTop="8dp"
            android:paddingRight="12dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvCatalogTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MQ-2103"
                android:textColor="#0965AF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCatalogSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Madrejon"
                android:textColor="#F28E1B"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:id="@+id/vfPromoCarousel"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_catalog_promo_1"
                android:gravity="bottom|start"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tvPromoTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Promociones"
                    android:textColor="#0965AF"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPromoSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Espacio para ofertas y anuncios"
                    android:textColor="#0965AF"
                    android:textSize="18sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCatalogStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_catalog_status"
                android:padding="10dp"
                android:text="Cargando catalogo..."
                android:textColor="#0965AF"
                android:textSize="16sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/llCatalogContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

        </LinearLayout>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/cartFabContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="52dp"
        android:layout_marginEnd="16dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="8dp">

        <ImageView
            android:id="@+id/ivCartBadge"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_cart_badge"
            android:padding="10dp"
            android:src="@drawable/ic_cart_fab"
            android:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tvCartBadge"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="top|end"
            android:background="@drawable/bg_cart_count_badge"
            android:gravity="center"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </FrameLayout>

</FrameLayout>
