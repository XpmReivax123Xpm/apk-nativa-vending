<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingLeft="4dp"
    android:paddingTop="4dp"
    android:paddingRight="4dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="84dp"
            android:layout_height="74dp"
            android:background="@drawable/bg_catalog_image_placeholder">

            <ImageView
                android:id="@+id/ivCartItemPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:contentDescription="preview"
                android:padding="0dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCartItemName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="A1 - Producto"
                android:textColor="#20344D"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCartItemPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Unitario: Bs 0.00"
                android:textColor="#5C7997"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvCartItemSubtotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:text="0.00 Bs"
            android:textColor="#20344D"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <View
            android:layout_width="94dp"
            android:layout_height="1dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnCartQtyMinus"
                android:layout_width="34dp"
                android:layout_height="32dp"
                android:backgroundTint="#F28E1B"
                android:contentDescription="restar"
                android:padding="7dp"
                android:src="@drawable/ic_minus_white" />

            <TextView
                android:id="@+id/tvCartQty"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="1"
                android:textColor="#0965AF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnCartQtyPlus"
                android:layout_width="34dp"
                android:layout_height="32dp"
                android:backgroundTint="#0965AF"
                android:contentDescription="sumar"
                android:padding="7dp"
                android:src="@drawable/ic_plus_white" />

            <ImageButton
                android:id="@+id/btnCartRemove"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="quitar item"
                android:padding="5dp"
                android:src="@android:drawable/ic_menu_delete"
                android:tint="#D94A3A" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/vCartItemDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="4dp"
        android:background="#D6E0EA" />

</LinearLayout>
