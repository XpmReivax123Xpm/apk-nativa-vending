<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <solid android:color="#344A66" />
            <stroke
                android:width="1dp"
                android:color="#516988" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="0"
                android:endColor="#2D415E"
                android:startColor="#364D6F"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#506D93" />
        </shape>
    </item>
</selector>

