<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_modal_surface"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pago con Yape"
        android:textColor="#0E2A47"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Ingresa tu numero vinculado a Yape para continuar."
        android:textColor="#365574"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etYapePhone"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#0965AF"
        android:gravity="center_vertical"
        android:hint="Numero Yape"
        android:imeOptions="actionDone"
        android:inputType="phone"
        android:maxLength="12"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:textColor="#0E2A47"
        android:textColorHint="#8AA0B6" />

    <TextView
        android:id="@+id/tvYapePhoneError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="#D62828"
        android:textSize="13sp"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/progressYapePhone"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnYapePhoneCancel"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:backgroundTint="#0965AF"
            android:text="Cancelar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnYapePhoneSend"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginLeft="8dp"
            android:backgroundTint="#F28E1B"
            android:text="Enviar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
