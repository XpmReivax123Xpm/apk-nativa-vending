<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end|center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <TextView
            android:id="@+id/tvFusionDialogTimer"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="2"
            android:text="60s"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnFusionDialogClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginLeft="8dp"
            android:background="@drawable/bg_btn_close_strong"
            android:contentDescription="Cerrar"
            android:gravity="center"
            android:text="X"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:background="@drawable/bg_modal_surface"
        android:orientation="horizontal"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="606dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingRight="8dp">

            <TextView
                android:id="@+id/tvFusionProductCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_chip_small_dark"
                android:paddingLeft="10dp"
                android:paddingTop="4dp"
                android:paddingRight="10dp"
                android:paddingBottom="4dp"
                android:text="Casilla 00"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivFusionProductPreview"
                android:layout_width="273dp"
                android:layout_height="298dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="false"
                android:contentDescription="preview"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_menu_gallery" />

            <TextView
                android:id="@+id/tvFusionProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:maxLines="1"
                android:singleLine="true"
                android:scrollHorizontally="true"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:text="Producto"
                android:gravity="center"
                android:textColor="#0E2A47"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="Elige cuántos quieres"
                android:textColor="#0965AF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnFusionQtyMinus"
                    android:layout_width="52dp"
                    android:layout_height="40dp"
                    android:backgroundTint="#0965AF"
                    android:contentDescription="restar cantidad"
                    android:padding="8dp"
                    android:src="@drawable/ic_minus_white" />

                <TextView
                    android:id="@+id/tvFusionQty"
                    android:layout_width="58dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="#000000"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btnFusionQtyPlus"
                    android:layout_width="52dp"
                    android:layout_height="40dp"
                    android:backgroundTint="#0965AF"
                    android:contentDescription="sumar cantidad"
                    android:padding="8dp"
                    android:src="@drawable/ic_plus_white" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvFusionProductStock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Stock: 0"
                android:textColor="#F28E1B"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFusionProductPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Precio unidad: Bs 0.00"
                android:textColor="#0E2A47"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnFusionAddCart"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="#0965AF"
                android:text="SELECCIONAR PRODUCTO"
                android:textSize="22sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#C9D8E7" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="606dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TUS PRODUCTOS SELECCIONADOS"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="380dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_cart_list_shell"
                android:orientation="vertical"
                android:padding="8dp">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:overScrollMode="ifContentScrolls">

                    <LinearLayout
                        android:id="@+id/llFusionCartItemsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </ScrollView>
            </LinearLayout>

            <TextView
                android:id="@+id/tvFusionCartUnits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Total unidades: 0"
                android:textColor="#0965AF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFusionCartTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Total a pagar: Bs 0.00"
                android:textColor="#0E2A47"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnFusionBuyCart"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#F28E1B"
                android:text="FINALIZAR PEDIDO"
                android:textSize="22sp"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnFusionClearCart"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="9dp"
                android:backgroundTint="#E00000"
                android:text="BORRAR PRODUCTOS"
                android:textSize="22sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
